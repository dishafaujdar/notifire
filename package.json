{
  "name": "notifire-core",
  "version": "0.1.0",
  "description": "Self-hosted notification library for Node.js.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "migrations",
    "templates",
    "README.md",
    "license"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "bullmq": "^5.79.3",
    "dotenv": "^17.4.2",
    "handlebars": "^4.7.8",
    "ioredis": "^5.11.1",
    "nodemailer": "^6.9.16",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^6.4.17",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^2.1.9",
    "tsup": "^8.3.5",
    "tsx": "^4.23.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dishafaujdar/notifire.git"
  },
  "homepage": "https://github.com/dishafaujdar/notifire#readme",
  "bugs": {
    "url": "https://github.com/dishafaujdar/notifire/issues"
  },
  "keywords": [
    "notification",
    "notifications",
    "email",
    "sms",
    "queue",
    "postgres",
    "bullmq",
    "redis",
    "workflow",
    "node"
  ],
  "peerDependencies": {
    "twilio": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "twilio": { "optional": true }
  }
}
