---
subject: "Your Notifyre verification code"
---
<!doctype html>
<html lang="en">
  <body style="margin:0;background:#f5f7fb;font-family:Arial,sans-serif;color:#1f2937;">
    <main style="max-width:560px;margin:0 auto;padding:32px 20px;">
      <section style="background:#ffffff;border:1px solid #e5e7eb;border-radius:8px;padding:28px;">
        <h1 style="margin:0 0 16px;font-size:22px;line-height:1.3;color:#111827;">Verify your sign-in</h1>
        <p style="margin:0 0 20px;font-size:15px;line-height:1.6;">Use this one-time code to finish signing in:</p>
        <p style="margin:0 0 20px;font-size:32px;letter-spacing:6px;font-weight:700;color:#111827;">{{code}}</p>
        <p style="margin:0;font-size:14px;line-height:1.6;color:#4b5563;">This code expires in {{expiresInSec}} seconds. If you did not request it, you can ignore this email.</p>
      </section>
    </main>
  </body>
</html>
